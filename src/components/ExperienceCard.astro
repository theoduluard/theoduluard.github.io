---
interface Props {
  badge: string;
  badgeColor: 'blue' | 'green' | 'amber';
  title: string;
  company: string;
  companyUrl: string;
  location: string;
  companyDesc: string;
  period: string;
  bullets: string[];
  stack: string[];
  stackLabel: string;
}

const { badge, badgeColor, title, company, companyUrl, location, companyDesc, period, bullets, stack, stackLabel } = Astro.props;

const badgeClasses = {
  blue: 'bg-blue-900/40 text-blue-300',
  green: 'bg-green-900/40 text-green-300',
  amber: 'bg-amber-900/30 text-amber-400',
};

const bulletIconClasses = {
  blue: 'text-blue-500',
  green: 'text-green-500',
  amber: 'text-amber-500/80',
};

const periodClasses = {
  blue: 'text-blue-500',
  green: 'text-green-500',
  amber: 'text-amber-500/80',
};

const hoverClasses = {
  blue: 'hover:border-blue-500/50 group-hover:text-blue-400',
  green: 'hover:border-green-500/50 group-hover:text-green-400',
  amber: 'hover:border-amber-500/30 group-hover:text-amber-400',
};

const cardHover = badgeColor === 'blue' ? 'hover:border-blue-500/50' : badgeColor === 'amber' ? 'hover:border-amber-500/30' : 'hover:border-green-500/50';
const titleHover = badgeColor === 'blue' ? 'group-hover:text-blue-400' : badgeColor === 'amber' ? 'group-hover:text-amber-400' : 'group-hover:text-green-400';
---

<div class={`reveal bg-slate-900 border border-slate-800 rounded-xl p-8 ${cardHover} transition-colors group`}>
  <div class="flex flex-col md:flex-row md:justify-between md:items-start mb-5">
    <div>
      <div class="flex flex-wrap items-center gap-2 mb-3">
        <span class={`${badgeClasses[badgeColor]} text-xs font-bold px-2.5 py-1 rounded-full uppercase tracking-wider flex items-center gap-1.5`}>
          <svg aria-hidden="true" class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 14.5v-9l6 4.5-6 4.5z"/></svg>
          {badge}
        </span>
      </div>
      <h3 class={`text-2xl font-bold text-slate-200 ${titleHover} transition-colors`}>{title}</h3>
      <p class="text-slate-400 text-lg mt-1">
        <a href={companyUrl} target="_blank" rel="noopener noreferrer" class="hover:text-blue-400 transition-colors">{company}</a>
        <span class="text-slate-600 text-sm"> · {location}</span>
      </p>
      <p class="text-slate-500 text-sm mt-1 max-w-xl">{companyDesc}</p>
    </div>
    <span class={`${periodClasses[badgeColor]} font-mono text-sm mt-3 md:mt-0 shrink-0`}>{period}</span>
  </div>

  <ul class="text-slate-400 space-y-2.5 mt-2">
    {bullets.map((bullet) => (
      <li class="flex items-start gap-2.5">
        <svg aria-hidden="true" class={`w-4 h-4 ${bulletIconClasses[badgeColor]} mt-0.5 shrink-0`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
        <span set:html={bullet} />
      </li>
    ))}
  </ul>

  <div class="mt-6">
    <h4 class="text-xs font-semibold text-slate-500 mb-3 uppercase tracking-wider">{stackLabel}</h4>
    <div class="flex flex-wrap gap-2">
      {stack.map((item) => (
        <span class="bg-slate-950 border border-slate-800 text-slate-300 text-xs px-3 py-1.5 rounded-md">{item}</span>
      ))}
    </div>
  </div>
</div>
