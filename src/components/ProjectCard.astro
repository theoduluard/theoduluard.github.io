---
interface Link {
	label: string;
	href: string;
	icon: 'github' | 'play' | 'download';
	variant?: 'primary' | 'secondary';
	primaryColor?: 'blue' | 'orange';
}

interface Props {
	color: 'rose' | 'blue' | 'purple' | 'cyan' | 'yellow' | 'green' | 'orange';
	categoryLabel: string;
	categoryIcon: string;
	levelLabel: string;
	title: string;
	description: string;
	bullets: string[];
	stack: string[];
	stackLabel?: string;
	links: Link[];
	revealClass?: string;
	demoPanelClass?: string;
}

const {
	color,
	categoryLabel,
	categoryIcon,
	levelLabel,
	title,
	description,
	bullets,
	stack,
	stackLabel = 'Stack Technique',
	links,
	revealClass = 'reveal',
	demoPanelClass = 'p-6 flex items-center justify-center',
} = Astro.props;

const colors = {
	rose:   { badge: 'bg-rose-900/50 text-rose-400',     bullet: 'text-rose-500',   hover: 'hover:border-rose-500/40',   glow: 'hover:shadow-[0_8px_32px_rgba(244,63,94,0.18)]'    },
	blue:   { badge: 'bg-blue-900/50 text-blue-400',     bullet: 'text-blue-500',   hover: 'hover:border-blue-500/40',   glow: 'hover:shadow-[0_8px_32px_rgba(59,130,246,0.18)]'   },
	purple: { badge: 'bg-purple-900/50 text-purple-400', bullet: 'text-purple-500', hover: 'hover:border-purple-500/40', glow: 'hover:shadow-[0_8px_32px_rgba(168,85,247,0.18)]'   },
	cyan:   { badge: 'bg-cyan-900/50 text-cyan-400',     bullet: 'text-cyan-500',   hover: 'hover:border-cyan-500/40',   glow: 'hover:shadow-[0_8px_32px_rgba(34,211,238,0.18)]'   },
	yellow: { badge: 'bg-yellow-900/50 text-yellow-400', bullet: 'text-yellow-500', hover: 'hover:border-yellow-500/40', glow: 'hover:shadow-[0_8px_32px_rgba(234,179,8,0.18)]'    },
	green:  { badge: 'bg-green-900/50 text-green-400',   bullet: 'text-green-500',  hover: 'hover:border-green-500/40',  glow: 'hover:shadow-[0_8px_32px_rgba(34,197,94,0.18)]'    },
	orange: { badge: 'bg-orange-900/50 text-orange-400', bullet: 'text-orange-500', hover: 'hover:border-orange-500/40', glow: 'hover:shadow-[0_8px_32px_rgba(249,115,22,0.18)]'   },
};

const primaryColors: Record<string, string> = {
	blue:   'bg-blue-600 hover:bg-blue-500 text-white shadow-[0_0_15px_rgba(59,130,246,0.3)] transition-all',
	orange: 'bg-orange-600 hover:bg-orange-500 text-white shadow-[0_0_15px_rgba(234,88,12,0.3)] transition-all',
};

const ICONS = {
	github: `<svg aria-hidden="true" class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>`,
	play:   `<svg aria-hidden="true" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" /><path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>`,
	download: `<svg aria-hidden="true" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" /></svg>`,
};

const c = colors[color];
---

<div class={`${revealClass} bg-slate-900 border border-slate-800 rounded-2xl overflow-hidden ${c.hover} ${c.glow} hover:-translate-y-1 transition-all duration-300 shadow-lg mt-8`}>
	<div class="flex flex-col lg:flex-row">

		<!-- Left: project info -->
		<div class="p-8 lg:w-1/2 flex flex-col justify-between">
			<div>
				<div class="flex items-center gap-3 mb-4">
					<span class={`${c.badge} text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wider flex items-center gap-1.5`}>
						<Fragment set:html={categoryIcon} />
						{categoryLabel}
					</span>
					<span class="bg-slate-800 text-slate-400 text-[10px] font-bold px-2 py-1 rounded uppercase">{levelLabel}</span>
				</div>

				<h3 class="text-3xl font-bold text-slate-100 mb-4">{title}</h3>

				<p class="text-slate-400 leading-relaxed mb-4" set:html={description} />

				<ul class="text-slate-400 text-sm space-y-2 mb-6 ml-1">
					{bullets.map((bullet) => (
						<li class="flex items-start gap-2">
							<svg class={`w-4 h-4 ${c.bullet} mt-0.5 shrink-0`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
								<path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
							</svg>
							<span set:html={bullet} />
						</li>
					))}
				</ul>

				<div class="mb-8">
					<h4 class="text-sm font-semibold text-slate-500 mb-3 uppercase tracking-wider">{stackLabel}</h4>
					<div class="flex flex-wrap gap-2">
						{stack.map((item) => (
							<span class="bg-slate-950 border border-slate-800 text-slate-300 text-xs px-3 py-1.5 rounded-md">{item}</span>
						))}
					</div>
				</div>
			</div>

			<div class="flex flex-wrap gap-3 mt-auto">
				{links.map((link) => (
					<a
						href={link.href}
						target={link.href.startsWith('http') ? '_blank' : undefined}
						rel={link.href.startsWith('http') ? 'noopener noreferrer' : undefined}
						class={`text-sm font-semibold py-2.5 px-5 rounded-lg flex items-center gap-2 ${
							link.variant === 'primary'
								? (link.primaryColor ? primaryColors[link.primaryColor] : primaryColors.blue)
								: 'bg-slate-800 hover:bg-slate-700 text-slate-200 border border-slate-700 transition-colors'
						}`}
					>
						<Fragment set:html={ICONS[link.icon]} />
						{link.label}
					</a>
				))}
			</div>
		</div>

		<!-- Right: demo panel (slot) -->
		<div class={`lg:w-1/2 bg-slate-950 border-l border-slate-800 ${demoPanelClass}`}>
			<slot />
		</div>

	</div>
</div>
