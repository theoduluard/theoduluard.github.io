---
// src/pages/en/index.astro
import Layout from '../../layouts/Layout.astro';
import ArchitectureSimulator from '../../components/ArchitectureSimulator.tsx';
import SectionHeader from '../../components/SectionHeader.astro';
import EducationEntry from '../../components/EducationEntry.astro';
import ExperienceCard from '../../components/ExperienceCard.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import AlloMissionDemo from '../../components/demos/AlloMissionDemo.astro';
import JibraxDemo from '../../components/demos/JibraxDemo.astro';
import RoboMLDemo from '../../components/demos/RoboMLDemo.astro';
import CICDDemo from '../../components/demos/CICDDemo.astro';
import AtWokDemo from '../../components/demos/AtWokDemo.astro';
import JacoBhashiDemo from '../../components/demos/JacoBhashiDemo.astro';
---

<Layout title="Théo DULUARD — Portfolio" lang="en" description="Portfolio of Théo DULUARD — Software Engineer specializing in Java backend and React frontend development.">

	<!-- ══════════════ HERO ══════════════ -->
	<section class="relative py-6 md:py-10 overflow-hidden">

		<div class="relative z-10 max-w-4xl mx-auto text-center">

			<div class="hero-reveal hero-delay-1 inline-flex items-center gap-2 bg-slate-900 border border-slate-800 text-slate-300 text-sm px-4 py-2 rounded-full mb-10">
				<span class="w-2 h-2 rounded-full bg-orange-400 animate-pulse shrink-0"></span>
				Apprenticeship @ Horizon Trading Solutions
			</div>

			<h1 class="hero-reveal hero-delay-2 text-6xl md:text-7xl lg:text-8xl font-extrabold tracking-tight leading-tight mb-5">
				Théo <span class="text-gradient-animated">DULUARD</span>
			</h1>

			<p class="hero-reveal hero-delay-3 text-xl md:text-2xl text-slate-400 font-medium mb-6">
				Software Engineer
			</p>

			<p class="hero-reveal hero-delay-4 text-base md:text-lg text-slate-500 max-w-2xl mx-auto mb-10 leading-relaxed">
				Master's graduate in Computer Science with 2 years of apprenticeship experience. I specialize in Java/JS backend development and React on the frontend. Curious, rigorous and reliable, I strive to bring value to every project I work on.
			</p>

			<div class="hero-reveal hero-delay-5 flex flex-wrap justify-center gap-3 mb-14">
				<a href="#projects" class="bg-blue-600 hover:bg-blue-500 text-white font-semibold py-3 px-7 rounded-xl transition-all shadow-[0_0_25px_rgba(59,130,246,0.4)] hover:shadow-[0_0_35px_rgba(59,130,246,0.55)]">
					View my projects
				</a>
				<a href="https://github.com/theoduluard" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 bg-slate-900 hover:bg-slate-800 border border-slate-700 text-slate-200 font-semibold py-3 px-6 rounded-xl transition-colors">
					<svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
					GitHub
				</a>
				<a href="https://www.linkedin.com/in/théo-duluard" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 bg-slate-900 hover:bg-slate-800 border border-slate-700 text-slate-200 font-semibold py-3 px-6 rounded-xl transition-colors">
					<svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
					LinkedIn
				</a>
			</div>

			<!-- Stack logos -->
			<div class="hero-reveal hero-delay-6">
				<p class="text-xs text-slate-600 uppercase tracking-widest mb-4">Main stack</p>
				<div class="flex flex-wrap justify-center gap-3">
					{[
						{ label: 'Java',         color: 'text-orange-400', bg: 'bg-orange-950/40 border-orange-800/40',  svg: '<svg viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4"><path d="M8.851 18.56s-.917.534.653.714c1.902.218 2.874.187 4.969-.211 0 0 .552.346 1.321.646-4.699 2.013-10.633-.118-6.943-1.149M8.276 15.933s-1.028.761.542.924c2.032.209 3.636.227 6.413-.308 0 0 .384.389.987.602-5.679 1.661-12.007.13-7.942-1.218M13.116 11.475c1.158 1.333-.304 2.533-.304 2.533s2.939-1.518 1.589-3.418c-1.261-1.772-2.228-2.652 3.007-5.688 0 0-8.216 2.051-4.292 6.573M19.33 20.504s.679.559-.747.991c-2.712.822-11.288 1.069-13.669.033-.856-.373.749-.89 1.254-.998.527-.114.828-.093.828-.093-.953-.671-6.156 1.317-2.643 1.887 9.58 1.553 17.462-.7 14.977-1.82M9.292 13.21s-4.362 1.036-1.544 1.412c1.189.159 3.561.123 5.77-.062 1.806-.152 3.618-.477 3.618-.477s-.637.272-1.098.587c-4.429 1.165-12.986.623-10.522-.568 2.082-1.006 3.776-.892 3.776-.892M17.116 17.584c4.503-2.34 2.421-4.589.968-4.285-.355.074-.515.138-.515.138s.132-.207.385-.297c2.875-1.011 5.086 2.981-.928 4.562 0 .001.07-.062.09-.118M14.401 0s2.494 2.494-2.365 6.33c-3.896 3.077-.888 4.832-.001 6.836-2.274-2.053-3.943-3.858-2.824-5.539 1.644-2.469 6.197-3.665 5.19-7.627M9.734 23.924c4.322.277 10.959-.153 11.116-2.198 0 0-.302.775-3.572 1.391-3.688.694-8.239.613-10.937.168 0 .001.553.457 3.393.639"/></svg>' },
						{ label: 'Spring Boot',  color: 'text-green-400',  bg: 'bg-green-950/40 border-green-800/40',   svg: '<svg viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4"><path d="M20.205 16.392c-2.469 3.289-7.741 2.179-11.122 2.338 0 0-.599.034-1.201.133 0 0 .228-.097.519-.198 2.374-.821 3.496-.986 4.939-1.727 2.71-1.388 5.408-4.413 5.957-7.555-1.032 3.022-4.17 5.623-7.027 6.679-1.955.722-5.492 1.424-5.493 1.424a5.28 5.28 0 01-.143-.076c-2.405-1.17-2.475-6.38 1.894-8.059 1.916-.736 3.747-.332 5.818-.825 2.208-.525 4.766-2.18 5.805-4.344 1.165 3.458 2.565 8.866.054 12.21zm.042-13.28a9.212 9.212 0 01-1.065 1.89 9.982 9.982 0 00-7.958-4.002c-5.514 0-9.99 4.475-9.99 9.99 0 5.517 4.476 9.992 9.99 9.992 5.517 0 9.992-4.475 9.992-9.991 0-2.842-1.189-5.405-3.098-7.232 1.158-.696 2.12-1.674 2.129-1.682z"/></svg>' },
						{ label: 'React',        color: 'text-cyan-400',   bg: 'bg-cyan-950/40 border-cyan-800/40',     svg: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-4 h-4"><circle cx="12" cy="12" r="2"/><ellipse cx="12" cy="12" rx="10" ry="3.5"/><ellipse cx="12" cy="12" rx="10" ry="3.5" transform="rotate(60 12 12)"/><ellipse cx="12" cy="12" rx="10" ry="3.5" transform="rotate(120 12 12)"/></svg>' },
						{ label: 'JavaScript',   color: 'text-yellow-400', bg: 'bg-yellow-950/40 border-yellow-800/40', svg: '<svg viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4"><path d="M0 0h24v24H0V0zm22.034 18.276c-.175-1.095-.888-2.015-3.003-2.873-.736-.345-1.554-.585-1.797-1.14-.091-.33-.105-.51-.046-.705.15-.646.915-.84 1.515-.66.39.12.75.42.976.9 1.034-.676 1.034-.676 1.755-1.125-.27-.42-.404-.601-.586-.78-.63-.705-1.469-1.065-2.834-1.034l-.705.089c-.676.165-1.32.525-1.71 1.005-1.14 1.291-.811 3.541.569 4.471 1.365 1.02 3.361 1.244 3.616 2.205.24 1.17-.87 1.545-1.966 1.41-.811-.18-1.26-.586-1.755-1.336l-1.83 1.051c.21.48.45.689.81 1.109 1.74 1.756 6.09 1.666 6.871-1.004.029-.09.24-.705.074-1.65l.046.067zm-8.983-7.245h-2.248c0 1.938-.009 3.864-.009 5.805 0 1.232.063 2.363-.138 2.711-.33.689-1.18.601-1.566.48-.396-.196-.597-.466-.83-.855-.063-.105-.11-.196-.127-.196l-1.825 1.125c.305.63.75 1.172 1.324 1.517.855.51 2.004.675 3.207.405.783-.226 1.458-.691 1.811-1.411.51-.93.402-2.07.397-3.346.012-2.054 0-4.109 0-6.179l.004-.056z"/></svg>' },
						{ label: 'TypeScript',   color: 'text-blue-400',   bg: 'bg-blue-950/40 border-blue-800/40',     svg: '<svg viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4"><path d="M1.125 0C.502 0 0 .502 0 1.125v21.75C0 23.498.502 24 1.125 24h21.75c.623 0 1.125-.502 1.125-1.125V1.125C24 .502 23.498 0 22.875 0zm17.363 9.75c.612 0 1.154.037 1.627.111a6.38 6.38 0 011.306.34v2.458a3.95 3.95 0 00-.643-.361 5.093 5.093 0 00-.717-.26 5.453 5.453 0 00-1.426-.2c-.3 0-.573.028-.819.086a2.1 2.1 0 00-.623.242c-.17.104-.3.229-.393.374a.888.888 0 00-.14.49c0 .196.053.373.156.529.104.156.252.304.443.444s.423.276.696.41c.273.135.582.274.926.416.47.197.892.407 1.266.628.374.222.695.473.963.753.268.279.472.598.614.957.142.359.214.776.214 1.253 0 .657-.125 1.21-.373 1.656a3.033 3.033 0 01-1.012 1.085 4.38 4.38 0 01-1.487.596c-.566.12-1.163.18-1.79.18a9.916 9.916 0 01-1.84-.164 5.544 5.544 0 01-1.512-.493v-2.63a5.033 5.033 0 003.237 1.2c.333 0 .624-.03.872-.09.249-.06.456-.144.623-.25.166-.108.29-.234.373-.38a1.023 1.023 0 00-.074-1.089 2.12 2.12 0 00-.537-.5 5.597 5.597 0 00-.807-.444 27.72 27.72 0 00-1.007-.436c-.918-.383-1.602-.852-2.053-1.405-.45-.553-.676-1.222-.676-2.005 0-.614.123-1.141.369-1.582.246-.441.58-.804 1.004-1.089a4.494 4.494 0 011.47-.629 7.536 7.536 0 011.77-.201zm-15.113.188h9.563v2.166H9.506v9.646H6.789v-9.646H3.375z"/></svg>' },
						{ label: 'Docker',        color: 'text-sky-400',    bg: 'bg-sky-950/40 border-sky-800/40',       svg: '<svg viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4"><rect x="2" y="9" width="4" height="3" rx="0.5"/><rect x="7" y="9" width="4" height="3" rx="0.5"/><rect x="12" y="9" width="4" height="3" rx="0.5"/><rect x="7" y="5" width="4" height="3" rx="0.5"/><rect x="12" y="5" width="4" height="3" rx="0.5"/><rect x="12" y="1" width="4" height="3" rx="0.5"/><path d="M18 13H2c0 3.31 3.58 6 8 6s8-2.69 8-6z"/></svg>' },
						{ label: 'PostgreSQL',    color: 'text-indigo-400', bg: 'bg-indigo-950/40 border-indigo-800/40', svg: '<svg viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4"><path d="M12 3C8.13 3 5 4.34 5 6v12c0 1.66 3.13 3 7 3s7-1.34 7-3V6c0-1.66-3.13-3-7-3zm5 12c0 .55-2.24 1.5-5 1.5S7 15.55 7 15v-1.89C8.45 13.72 10.17 14 12 14s3.55-.28 5-.89V15zm0-4.5c0 .55-2.24 1.5-5 1.5S7 11.05 7 10.5V8.61C8.45 9.22 10.17 9.5 12 9.5s3.55-.28 5-.89v1.89zM12 8C9.24 8 7 7.05 7 6.5S9.24 5 12 5s5 .95 5 1.5S14.76 8 12 8z"/></svg>' },
						{ label: 'GitLab CI',     color: 'text-rose-400',   bg: 'bg-rose-950/40 border-rose-800/40',    svg: '<svg viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4"><path d="M22.65 14.39L12 22.13 1.35 14.39a.84.84 0 01-.3-.94l1.22-3.78 2.44-7.51A.42.42 0 014.82 2a.43.43 0 01.58 0 .42.42 0 01.11.18l2.44 7.49h8.1l2.44-7.51A.42.42 0 0118.6 2a.43.43 0 01.58 0 .42.42 0 01.11.18l2.44 7.51L23 13.45a.84.84 0 01-.35.94z"/></svg>' },
					].map((tech, i) => (
						<span
							class={`hero-reveal inline-flex items-center gap-1.5 ${tech.bg} border ${tech.color} text-xs font-medium px-3 py-1.5 rounded-full`}
							style={`animation-delay: ${700 + i * 60}ms`}
						>
							<Fragment set:html={tech.svg} />
							{tech.label}
						</span>
					))}
				</div>
			</div>

		</div>
	</section>

	<!-- ══════════════ EDUCATION ══════════════ -->
	<section id="education" class="py-20 border-t border-slate-800">
		<SectionHeader number="01" title="Education" />

		<div class="space-y-16 border-l-2 border-slate-800 pl-8 ml-4">
			<EducationEntry
				revealClass="reveal"
				title="Master's in Computer Science — Software Engineering"
				school="University of Rennes"
				period="2024 - 2026"
				description="Programme focused on complex software design, distributed architectures and software quality. Grounded in modern industry practices: microservices, cloud, formal verification and mobile development."
				conceptsLabel="Topics covered"
				concepts={[
					"Software Architecture (Microservices, Monolithic)",
					"Design Patterns",
					"DSL & Language Engineering",
					"Logic Programming (Prolog)",
					"Database Design",
					"Solution Security",
					"WebSocket & Message Broker (RabbitMQ)",
				]}
				techsLabel="Technologies & Tools"
				techs={["React", "Java", "JavaScript", "PostgreSQL", "MySQL", "Firebase", "Angular", "Keycloak", "Xtext", "Langium", "Postman", "JUnit", "GitLab"]}
			/>

			<EducationEntry
				revealClass="reveal delay-2"
				title="Bachelor's in Computer Science"
				school="University of Le Mans"
				period="2021 - 2024"
				description="Multidisciplinary programme covering the fundamentals of computer science: algorithms, object-oriented programming, databases, networking and web development. Completed alongside my apprenticeship at Horizon Trading Solutions."
				conceptsLabel="Topics covered"
				concepts={[
					"Algorithms & Data Structures",
					"Object-Oriented Programming",
					"Relational Databases",
					"Networking & Systems",
					"Web Development",
					"Software Engineering",
					"Design Patterns",
				]}
				techsLabel="Technologies & Tools"
				techs={["C", "Java", "Python", "JavaScript", "HTML", "CSS", "PostgreSQL", "GitHub", "Unix / Shell", "Prolog", "Haskell"]}
			/>

			<EducationEntry
				title="First year of Bachelor's — Mathematics & Applications"
				school="University of Le Mans"
				period="2020 - 2021"
				description="University year centred on mathematical foundations and their application to computer science and natural sciences. Strengthened my analytical rigour and capacity for abstraction, both valuable in programming and algorithms."
				conceptsLabel="Topics covered"
				concepts={[
					"Linear Algebra",
					"Analysis & Differential Calculus",
					"Probability & Statistics",
					"Mathematical Logic",
					"Introduction to Programming",
				]}
				techsLabel="Technologies & Tools"
				techs={["Python", "Scilab"]}
			/>
		</div>
	</section>

	<!-- ══════════════ EXPERIENCE ══════════════ -->
	<section id="experience" class="py-20 border-t border-slate-800">
		<SectionHeader number="02" title="Work Experience" />

		<div class="flex flex-col gap-6">
			<ExperienceCard
				badge="Apprenticeship · Ongoing"
				badgeColor="blue"
				title="Java Developer"
				company="Horizon Trading Solutions"
				companyUrl="https://www.hsoftware.com"
				location="Rennes, France"
				companyDesc="Publisher of real-time algorithmic trading solutions for investment banks and brokers (130+ employees, international presence)."
				period="Sept. 2024 — Aug. 2026"
				bullets={[
					'Design and development of a <strong class="text-slate-300">Functional Monitoring</strong> system for the H3 platform: real-time capture of client activity metrics via a high-performance messaging framework (<strong class="text-slate-300">Aeron</strong>).',
					'Centralisation of market events (orders, volumes) in a time-series database (<strong class="text-slate-300">InfluxDB</strong>) with visualisation via <strong class="text-slate-300">Grafana</strong>.',
					'Development of a data extraction process (<strong class="text-slate-300">Flux</strong> queries, CSV export) for analysing client activity volumes and tracking usage metrics.',
					'Various contributions: bug fixes, business logic improvements, exception handling in a distributed environment, unit and integration tests (JUnit, Mockito).',
					'Agile Scrum cycle (2-week sprints): grooming, estimation, systematic code review, quality control and continuous delivery.',
				]}
				stackLabel="Stack"
				stack={["Java", "Aeron", "InfluxDB", "Flux", "Grafana", "PostgreSQL", "JUnit · Mockito", "Gradle", "GitLab", "Jenkins", "Jira · Scrum"]}
			/>

			<ExperienceCard
				badge="Pre-hire internship"
				badgeColor="amber"
				title="Java Developer — Integration & Onboarding"
				company="Horizon Trading Solutions"
				companyUrl="https://www.hsoftware.com"
				location="Rennes, France"
				companyDesc="Pre-hire internship ahead of the Master's apprenticeship, embedded in a Scrum team on the H3 trading platform."
				period="Jul. — Sept. 2024"
				bullets={[
					'Onboarding and setup of the development environment (IntelliJ IDEA, Git, Gradle, Jenkins) and functional discovery of the H3 trading platform.',
					'Configuration of a full local trading environment: importing financial instruments, order management and reading the market depth book.',
					'Development of a Java market connectivity client: subscription to real-time event streams (orders, depth), order submission and implementation of an automated response strategy.',
					'Autonomous completion of first Jira tickets: feature development and Java fixes within the team Scrum cycle.',
				]}
				stackLabel="Stack"
				stack={["Java", "IntelliJ IDEA", "JUnit · Mockito", "Git", "Gradle", "Docker", "Jira · Scrum"]}
			/>
		</div>
	</section>

	<!-- ══════════════ PROJECTS ══════════════ -->
	<section id="projects" class="py-20 border-t border-slate-800">
		<SectionHeader number="03" title="Personal & Academic Projects" />

		<!-- VoiceMail AI Assistant -->
		<ProjectCard
			color="rose"
			categoryLabel="Microservices & AI"
			categoryIcon='<svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" /></svg>'
			levelLabel="Master's 2"
			title="VoiceMail AI Assistant"
			description="AI-powered voice email assistant built around a <strong>BFF</strong> pattern orchestrating multiple microservices (11 Docker containers) with local LLM processing."
			bullets={[
				'<strong>Privacy by Design:</strong> Automatic anonymisation of personal data before model processing.',
				'<strong>Local NLU:</strong> Intent analysis via Ollama (Llama 3.1) to generate schema-validated JSON action plans.',
			]}
			stack={["React TS", "Spring Boot", "Ollama 3", "Docker", "Keycloak", "GitLab CI"]}
			stackLabel="Tech Stack"
			links={[{ label: "Source Code", href: "https://github.com/theoduluard/LazyMail", icon: "github" }]}
			demoPanelClass="overflow-hidden flex items-center justify-center"
		>
			<ArchitectureSimulator client:visible />
		</ProjectCard>

		<!-- Allo-Mission -->
		<ProjectCard
			color="blue"
			categoryLabel="Mobile App"
			categoryIcon='<svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" /></svg>'
			levelLabel="Master's 2"
			title="Allo-Mission"
			description="Professional networking platform. Recruiters can post detailed job listings while candidates can browse and apply directly from their smartphone."
			bullets={[
				'<strong>Dual role:</strong> Dedicated recruiter interface (posting, offer management) and candidate interface (search, one-tap application).',
				'<strong>Firebase Auth:</strong> Account management, session persistence and real-time data security.',
				'<strong>Cross-platform:</strong> Expo app deployed on iOS and Android from a single TypeScript codebase.',
			]}
			stack={["React Native", "TypeScript", "Expo", "Firebase"]}
			stackLabel="Tech Stack"
